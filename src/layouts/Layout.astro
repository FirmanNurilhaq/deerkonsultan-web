---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body>
		<nav class="fixed w-full z-50 px-4 pt-6">
			<div class="max-w-6xl mx-auto glass rounded-2xl h-16 flex items-center justify-between px-8 shadow-2xl">
				<a href="/" class="text-xl font-black tracking-tighter text-white hover:scale-105 transition-transform">
					DEER<span class="text-indigo-400">WORSHIPER.</span>
				</a>
				
				<div class="hidden md:flex items-center space-x-8 text-sm font-bold uppercase tracking-widest text-slate-400">
					<a href="/#layanan" class="hover:text-white transition">Layanan</a>
					<a href="/blog" class="hover:text-white transition flex items-center gap-2">
						Wawasan <span class="w-1.5 h-1.5 bg-indigo-500 rounded-full"></span>
					</a>
					<a href="https://wa.me/your-number" class="bg-indigo-600 hover:bg-indigo-500 text-white px-6 py-2 rounded-xl transition-all shadow-[0_0_20px_rgba(99,102,241,0.4)]">
						Konsultasi
					</a>
				</div>
			</div>
		</nav>

		<main>
			<slot />
		</main>

		<footer class="bg-[#010409] border-t border-white/5 py-20">
			<div class="max-w-7xl mx-auto px-4 grid md:grid-cols-2 gap-20">
				<div>
					<p class="text-3xl font-black text-white mb-6 uppercase tracking-tighter">Deerworshiper</p>
					<p class="text-slate-500 max-w-sm leading-relaxed">
						Membantu pemimpin bisnis menavigasi kompleksitas digital dengan strategi berbasis data dan eksekusi presisi.
					</p>
				</div>
				<div class="grid grid-cols-2 gap-8">
					<div class="space-y-4 text-sm">
						<p class="text-white font-bold uppercase tracking-widest">Kontak</p>
						<p class="text-slate-500">Bandung, Jawa Barat</p>
						<p class="text-indigo-400 font-bold underline">halo@deerkonsultan.com</p>
					</div>
					<div class="space-y-4 text-sm">
						<p class="text-white font-bold uppercase tracking-widest">Karier</p>
						<p class="text-slate-500">Kami selalu mencari talenta terbaik untuk bergabung.</p>
					</div>
				</div>
			</div>
			<div class="max-w-7xl mx-auto px-4 mt-20 pt-8 border-t border-white/5 flex justify-between items-center text-[10px] uppercase tracking-[0.3em] text-slate-600">
				<p>© 2026 DEERWORSHIPER CONSULTING</p>
				<p>DESIGNED BY MANZ</p>
			</div>
		</footer>
	</body>
</html>