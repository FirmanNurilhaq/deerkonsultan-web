---
import Layout from '../layouts/Layout.astro';
// Mengambil data dari file JSON agar sinkron dengan halaman detail
import services from '../data/services.json';
---

<Layout 
	title="Deerworshiper Consulting | Partner Strategis Bisnis Anda"
	description="Kami menyediakan jasa konsultasi profesional untuk membantu bisnis Anda mencapai target maksimal di era digital."
>
	<section class="py-20 px-4 bg-gradient-to-b from-indigo-50 to-white text-center">
		<div class="max-w-4xl mx-auto">
			<h1 class="text-5xl md:text-6xl font-extrabold text-slate-900 mb-6 leading-tight">
				Tingkatkan Level Bisnis Anda Bersama <span class="text-indigo-600">Expert</span>.
			</h1>
			<p class="text-lg text-slate-600 mb-10 max-w-2xl mx-auto font-medium">
				Deerworshiper Consulting hadir untuk memberikan solusi nyata bagi tantangan bisnis Anda di era digital.
			</p>
			<div class="flex flex-col md:flex-row gap-4 justify-center">
				<a href="#layanan" class="px-8 py-4 bg-indigo-600 text-white font-bold rounded-xl shadow-lg hover:shadow-indigo-200 hover:-translate-y-1 transition-all duration-300">
					Lihat Layanan
				</a>
				<a href="#tentang" class="px-8 py-4 bg-white border border-slate-200 font-bold rounded-xl text-slate-700 hover:bg-slate-50 transition-all duration-300">
					Tentang Kami
				</a>
			</div>
		</div>
	</section>

	<section id="layanan" class="py-24 max-w-7xl mx-auto px-4">
		<div class="text-center mb-16">
			<h2 class="text-3xl md:text-4xl font-bold mb-4 text-slate-900">Layanan Unggulan</h2>
			<div class="h-1.5 w-20 bg-indigo-600 mx-auto rounded-full"></div>
			<p class="mt-6 text-slate-500 max-w-xl mx-auto">Klik pada layanan untuk melihat detail strategi yang kami tawarkan untuk bisnis Anda.</p>
		</div>
		
		<div class="grid md:grid-cols-3 gap-8">
			{services.map(service => (
				<a 
					href={`/layanan/${service.slug}`} 
					class="group p-8 bg-white rounded-3xl border border-slate-100 shadow-sm hover:shadow-2xl hover:border-indigo-100 transition-all duration-500 overflow-hidden relative"
				>
					<div class="absolute top-0 right-0 w-24 h-24 bg-indigo-50 rounded-bl-full -mr-12 -mt-12 group-hover:scale-150 transition-transform duration-700 opacity-50"></div>
					
					<div class="text-5xl mb-6 transform group-hover:scale-110 transition-transform duration-300 inline-block">{service.icon}</div>
					<h3 class="text-2xl font-bold mb-3 text-slate-800 group-hover:text-indigo-600 transition-colors">{service.title}</h3>
					<p class="text-slate-600 leading-relaxed mb-6 line-clamp-2">
						{service.description}
					</p>
					
					<div class="flex items-center text-indigo-600 font-bold text-sm">
						Pelajari Strategi 
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 group-hover:translate-x-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</div>
				</a>
			))}
		</div>
	</section>

	<section class="py-20 px-4">
		<div class="max-w-5xl mx-auto bg-indigo-600 rounded-[2.5rem] p-12 md:p-20 text-center text-white relative overflow-hidden shadow-2xl shadow-indigo-200">
			<div class="absolute top-0 left-0 w-64 h-64 bg-white/10 rounded-full -ml-32 -mt-32 blur-3xl"></div>
			<div class="absolute bottom-0 right-0 w-64 h-64 bg-indigo-400/20 rounded-full -mr-32 -mb-32 blur-3xl"></div>

			<div class="relative z-10">
				<h2 class="text-3xl md:text-5xl font-bold mb-8">Siap Mengembangkan Bisnis Anda?</h2>
				<p class="mb-12 text-indigo-100 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
					Jangan biarkan kompetitor mendahului Anda. Konsultasikan kebutuhan perusahaan Anda secara gratis hari ini.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href="https://wa.me/your-number" class="bg-white text-indigo-600 px-10 py-4 rounded-2xl font-bold text-lg hover:bg-indigo-50 hover:scale-105 transition-all shadow-xl">
						Hubungi Kami Sekarang
					</a>
				</div>
			</div>
		</div>
	</section>
</Layout>