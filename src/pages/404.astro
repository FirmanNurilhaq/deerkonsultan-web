---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Halaman Tidak Ditemukan" description="Ups! Sepertinya Anda tersesat di luar strategi kami.">
	<section class="min-h-screen flex items-center justify-center text-center px-4">
		<div data-aos="zoom-in">
			<h1 class="text-[12rem] font-black tracking-tighter leading-none text-indigo-500 opacity-20">404</h1>
			<div class="-mt-20 relative">
				<h2 class="text-4xl font-black uppercase tracking-widest mb-6" style="color: var(--text-main)">Lost in Strategy?</h2>
				<p class="mb-12 max-w-md mx-auto" style="color: var(--text-muted)">Halaman yang Anda cari tidak ada atau telah dipindahkan ke masa depan.</p>
				<a href="/" class="px-10 py-5 bg-indigo-600 text-white font-black rounded-2xl hover:bg-indigo-500 shadow-2xl transition-all inline-block">
					Kembali ke Beranda
				</a>
			</div>
		</div>
	</section>
</Layout>