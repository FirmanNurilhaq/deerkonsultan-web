---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
	<article class="py-32 px-4 max-w-4xl mx-auto min-h-screen overflow-hidden">
		<header class="mb-16 text-center">
			<a href="/blog" 
               data-aos="fade-right"
               class="text-indigo-500 font-black text-[10px] uppercase tracking-[0.3em] mb-8 inline-block hover:opacity-70 transition-opacity">
				← Back to Insights
			</a>
			
			<h1 data-aos="fade-up"
                class="text-5xl md:text-7xl font-black mb-8 tracking-tighter leading-none transition-colors" 
                style="color: var(--text-main)">
				{post.data.title}
			</h1>
			
			<div data-aos="fade-up" 
                 data-aos-delay="200"
                 class="flex items-center justify-center gap-4 text-[10px] font-black uppercase tracking-widest transition-colors" 
                 style="color: var(--text-muted)">
				<span class="text-indigo-500">{post.data.author}</span>
				<span class="w-1 h-1 bg-current opacity-20 rounded-full"></span>
				<span>{post.data.pubDate.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
			</div>
		</header>

		<div class="relative group mb-20" data-aos="zoom-in" data-aos-duration="1000">
			<div class="absolute -inset-4 bg-indigo-500/10 rounded-[2.5rem] blur-2xl opacity-0 group-hover:opacity-100 transition duration-1000"></div>
			<img src={post.data.image} alt={post.data.title} class="relative w-full h-[500px] object-cover rounded-[2.5rem] shadow-2xl border border-white/5" />
		</div>

		<div data-aos="fade-up" 
             data-aos-delay="400"
             class="prose prose-indigo prose-xl max-w-none transition-colors
			prose-headings:font-black prose-headings:tracking-tighter prose-headings:uppercase
			dark:prose-invert" 
			style="color: var(--text-muted)">
			<Content />
		</div>

		<div data-aos="fade-up" 
             class="mt-32 p-12 md:p-20 glass rounded-[3rem] text-center relative overflow-hidden shadow-2xl">
			<div class="absolute inset-0 bg-indigo-500/5 -z-10"></div>
			<h3 class="text-3xl font-black mb-6 uppercase tracking-tight" style="color: var(--text-main)">Butuh Strategi Spesifik?</h3>
			<p class="mb-10 max-w-md mx-auto" style="color: var(--text-muted)">Mari diskusikan bagaimana transformasi ini dapat diterapkan untuk bisnis Anda.</p>
			<a href="https://wa.me/6285156936047" class="inline-block bg-indigo-600 text-white px-10 py-4 rounded-xl font-black uppercase tracking-widest text-sm hover:bg-indigo-500 transition-all shadow-lg active:scale-95">
				Mulai Diskusi
			</a>
		</div>
	</article>
</Layout>