---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout 
	title="Insights | Deerworshiper Consulting"
	description="Wawasan eksklusif mengenai strategi bisnis dan masa depan digital."
>
	<section class="relative py-32 px-4 min-h-screen overflow-hidden">
		<div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-indigo-500/5 rounded-full blur-[120px] -z-10"></div>

		<div class="max-w-7xl mx-auto">
			<header class="text-center mb-24">
				<p class="text-indigo-500 font-black text-[10px] uppercase tracking-[0.4em] mb-6">Expert Insights</p>
				<h1 class="text-6xl md:text-8xl font-black tracking-tighter uppercase mb-8 transition-colors" style="color: var(--text-main)">
					Latest <span class="text-gradient">Thought.</span>
				</h1>
				<div class="h-1.5 w-20 bg-indigo-500 mx-auto rounded-full"></div>
			</header>

			<div class="grid md:grid-cols-3 gap-8">
				{sortedPosts.map((post) => (
					<article class="group glass rounded-[2.5rem] overflow-hidden border-white/5 hover:border-indigo-500/30 transition-all duration-500 flex flex-col shadow-2xl">
						<div class="overflow-hidden h-64">
							<img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
						</div>
						<div class="p-10 flex flex-col flex-1">
							<div class="flex items-center gap-3 mb-6">
								<span class="text-[10px] font-black text-indigo-500 uppercase tracking-widest">
									{post.data.pubDate.toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric' })}
								</span>
							</div>
							
							<h2 class="text-2xl font-black mb-4 group-hover:text-indigo-500 transition-colors tracking-tight leading-tight" style="color: var(--text-main)">
								<a href={`/blog/${post.id}`}>{post.data.title}</a>
							</h2>
							
							<p class="text-sm leading-relaxed mb-8 flex-1 transition-colors" style="color: var(--text-muted)">
								{post.data.description}
							</p>
							
							<a href={`/blog/${post.id}`} class="text-xs font-black uppercase tracking-widest flex items-center gap-2 group-hover:gap-4 transition-all" style="color: var(--text-main)">
								Read Analysis <span class="text-indigo-500">→</span>
							</a>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>
</Layout>