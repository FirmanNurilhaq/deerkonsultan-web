---
import Layout from '../../layouts/Layout.astro';
import services from '../../data/services.json';

export async function getStaticPaths() {
	return services.map(service => ({
		params: { slug: service.slug },
		props: { service },
	}));
}

const { service } = Astro.props;
---

<Layout title={`${service.title} | Deerworshiper`} description={service.description}>
	<section class="pt-48 pb-32 px-4">
		<div class="max-w-5xl mx-auto">
			<div class="flex flex-col md:flex-row gap-16 items-start">
				<div class="flex-1" data-aos="fade-right">
					<span class="text-5xl mb-8 inline-block p-6 glass rounded-3xl">{service.icon}</span>
					<h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase mb-8" style="color: var(--text-main)">
						{service.title}
					</h1>
					<p class="text-xl leading-relaxed mb-10" style="color: var(--text-muted)">
						{service.description}
					</p>
					
					<div class="space-y-6">
						<h3 class="text-xs font-black uppercase tracking-widest text-indigo-500">Metodologi Kami</h3>
						<div class="grid gap-4">
							{["Discovery & Research", "Strategic Planning", "Execution & Quality Control", "Review & Optimization"].map((step, i) => (
								<div class="flex items-center gap-4 p-4 glass rounded-xl border-white/5" data-aos="fade-up" data-aos-delay={i * 100}>
									<span class="w-8 h-8 rounded-full bg-indigo-500 flex items-center justify-center text-[10px] font-black text-white">{i + 1}</span>
									<span class="font-bold uppercase text-[10px] tracking-widest" style="color: var(--text-main)">{step}</span>
								</div>
							))}
						</div>
					</div>
				</div>

				<div class="w-full md:w-80 space-y-8" data-aos="fade-left">
					<div class="p-8 glass rounded-[2.5rem] border-indigo-500/20 shadow-2xl">
						<h4 class="font-black text-xs uppercase tracking-widest mb-6" style="color: var(--text-main)">Tertarik?</h4>
						<p class="text-xs mb-8 opacity-70" style="color: var(--text-muted)">Konsultasikan kebutuhan bisnis Anda secara gratis selama 30 menit pertama.</p>
						<a href="https://wa.me/6285156936047" class="block w-full text-center bg-indigo-600 text-white py-4 rounded-xl font-bold text-[10px] uppercase tracking-widest hover:bg-indigo-500 transition-all">
							Hubungi Sekarang
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>