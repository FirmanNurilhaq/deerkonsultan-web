---
import Layout from '../../layouts/Layout.astro';
import services from '../../data/services.json';

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Layout 
  title={`${service.title} | Strategic Excellence`} 
  description={service.description}
>
  <section class="py-32 max-w-4xl mx-auto px-4 min-h-screen">
    <a href="/#layanan" class="group text-indigo-400 font-black text-xs uppercase tracking-widest mb-12 inline-flex items-center gap-2 hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform group-hover:-translate-x-2 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Back to Expertise
    </a>
    
    <div class="glass p-12 md:p-20 rounded-[3rem] border-white/5 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-indigo-600/10 rounded-full blur-[100px] -z-10"></div>
      
      <div class="text-7xl mb-10">{service.icon}</div>
      <h1 class="text-5xl md:text-7xl font-black mb-8 text-white tracking-tighter uppercase leading-none">
        {service.title}
      </h1>
      
      <div class="space-y-8 text-slate-400 text-lg leading-relaxed">
        <p class="text-white font-bold text-2xl border-l-4 border-indigo-500 pl-6 my-10">
          {service.description}
        </p>
        <p>{service.content}</p>
        
        <div class="mt-16 grid gap-6">
          <div class="p-8 rounded-2xl bg-white/5 border border-white/5 hover:border-indigo-500/30 transition-colors">
            <h3 class="text-white font-black uppercase tracking-widest mb-4 text-sm">Key Strategic Values</h3>
            <ul class="space-y-4">
              <li class="flex items-center gap-3 text-sm">
                <span class="h-1.5 w-1.5 bg-indigo-500 rounded-full"></span>
                Data-driven methodology for precision execution.
              </li>
              <li class="flex items-center gap-3 text-sm">
                <span class="h-1.5 w-1.5 bg-indigo-500 rounded-full"></span>
                Scalable architectures for global market expansion.
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>